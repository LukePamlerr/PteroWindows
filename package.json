{
  "name": "pterowindows",
  "version": "2.0.0",
  "description": "Pterodactyl Game Panel Manager for Windows - Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "npx @electron/packager . PteroWindows --platform=win32 --arch=x64 --out=dist --overwrite --ignore='node_modules|dist|.git|.github' --executable-name='PteroWindows'",
    "dist": "npm run pack && powershell Compress-Archive -Path dist/PteroWindows-win32-x64/* -DestinationPath dist/PteroWindows-portable.zip",
    "build": "npm run dist"
  },
  "keywords": [
    "pterodactyl",
    "panel",
    "wings",
    "games",
    "windows"
  ],
  "author": "LukePamlerr",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LukePamlerr/PteroWindows.git"
  },
  "bugs": {
    "url": "https://github.com/LukePamlerr/PteroWindows/issues"
  },
  "homepage": "https://github.com/LukePamlerr/PteroWindows"
}
