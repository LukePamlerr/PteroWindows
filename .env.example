# =============================================================================
# PteroWindows - Pterodactyl Panel on Windows
# Configuration File
# =============================================================================
# Copy this file to .env and fill in your values before running the installer.
#   copy .env.example .env
# =============================================================================

# --- Panel URL ---
# The full URL where your panel will be accessible (no trailing slash).
# For local testing: http://localhost
# For production: https://panel.yourdomain.com
APP_URL=http://localhost

# --- Timezone ---
# See https://www.php.net/manual/en/timezones.php for valid values.
APP_TIMEZONE=UTC

# --- Service Author ---
# Email address shown in the panel footer.
APP_SERVICE_AUTHOR=admin@example.com

# --- Database Passwords ---
# Generate strong passwords (minimum 16 chars).
DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# --- Environment ---
# Set to "production" for live use, "development" for testing.
APP_ENV=production
APP_ENVIRONMENT_ONLY=false

# --- HTTP/HTTPS Ports ---
# Ports to expose on the host (Windows).
# If ports 80/443 are in use, change these (e.g., 8080:80, 8443:443).
HTTP_PORT=80
HTTPS_PORT=443

# --- Let's Encrypt SSL (optional) ---
# Set your email to auto-provision SSL certificates.
# Requires APP_URL to be a public domain with DNS pointing to this host.
LE_EMAIL=

# --- Mail Settings (optional) ---
# Used for password resets and panel notifications.
MAIL_DRIVER=smtp
MAIL_HOST=mail.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=true
MAIL_FROM=noreply@example.com
